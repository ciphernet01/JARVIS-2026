# JARVIS Core - Security Policy
# Prevent secret leakage and telemetry bloat

# Secrets and sessions
.env
.env.*
*.env
.session_token
credentials.json
*.pem
*.key
*.cert
.credentials

# Python compiled files and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Frontend dependencies and build output
node_modules/
frontend/node_modules/
frontend/build/

# Local data and telemetry
*.log
*.db
*.sqlite
imagedata/
data/
logs/

# Binary and OS files
.DS_Store
Thumbs.db
*.exe
*.bin
*.pt
*.onnx

# Misc
*.old
*.test
debug_*.py
test_*_final.py
