# JARVIS Environment Configuration
# Copy this to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# OpenAI API Keys (for future enhancements)
# ============================================
JARVIS_OPENAI_API_KEY=your-openai-api-key-here
JARVIS_OPENAI_ORGANIZATION=your-organization-id

# ============================================
# Email Services
# ============================================
# Gmail
JARVIS_GMAIL_EMAIL=your-email@gmail.com
JARVIS_GMAIL_PASSWORD=your-app-password-here
# Note: Use app-specific passwords for Gmail, not your main password

# Outlook
JARVIS_OUTLOOK_EMAIL=your-email@outlook.com
JARVIS_OUTLOOK_PASSWORD=your-password-here

# ============================================
# Google APIs
# ============================================
JARVIS_GOOGLE_API_KEY=your-google-api-key
JARVIS_GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com
JARVIS_GOOGLE_CALENDAR_CREDENTIALS=path/to/credentials.json

# ============================================
# Social Media APIs
# ============================================
# Twitter/X
JARVIS_TWITTER_API_KEY=your-api-key
JARVIS_TWITTER_API_SECRET=your-api-secret
JARVIS_TWITTER_ACCESS_TOKEN=your-access-token
JARVIS_TWITTER_ACCESS_SECRET=your-access-secret

# Instagram
JARVIS_INSTAGRAM_USERNAME=your-username
JARVIS_INSTAGRAM_PASSWORD=your-password

# ============================================
# Spotify
# ============================================
JARVIS_SPOTIFY_CLIENT_ID=your-client-id
JARVIS_SPOTIFY_CLIENT_SECRET=your-client-secret
JARVIS_SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ============================================
# Voice & Speech APIs
# ============================================
# OpenAI Whisper (for advanced speech recognition)
JARVIS_WHISPER_API_KEY=your-whisper-key

# Azure Speech Services
JARVIS_AZURE_SPEECH_KEY=your-azure-key
JARVIS_AZURE_SPEECH_REGION=your-region

# Google Cloud Speech
JARVIS_GOOGLE_SPEECH_KEY=your-key
JARVIS_GOOGLE_SPEECH_PROJECT_ID=your-project

# ============================================
# Smart Home / IoT
# ============================================
# Home Assistant
JARVIS_HOME_ASSISTANT_URL=http://localhost:8123
JARVIS_HOME_ASSISTANT_TOKEN=your-long-lived-access-token

# SmartThings
JARVIS_SMARTTHINGS_API_KEY=your-api-key
JARVIS_SMARTTHINGS_DEVICE_ID=your-device-id

# LIFX (Smart Lights)
JARVIS_LIFX_API_KEY=your-api-key

# ============================================
# Database
# ============================================
JARVIS_DATABASE_URL=postgresql://user:password@localhost:5432/jarvis_db
# Alternatives:
# JARVIS_DATABASE_URL=mysql://user:password@localhost:3306/jarvis_db
# JARVIS_DATABASE_URL=sqlite:///jarvis.db

# ============================================
# Security & Encryption
# ============================================
# Encryption key (generated by --setup-security)
JARVIS_ENCRYPTION_KEY=your-encryption-key-here

# Secret key for session management
JARVIS_SECRET_KEY=your-secret-key-for-sessions

# Master password for admin functions
JARVIS_MASTER_PASSWORD=your-master-password

# ============================================
# News & Weather APIs
# ============================================
JARVIS_NEWS_API_KEY=your-newsapi-key
JARVIS_WEATHER_API_KEY=your-weatherapi-key
JARVIS_WEATHER_PROVIDER=openweathermap

# ============================================
# Stock Market & Finance
# ============================================
JARVIS_ALPHA_VANTAGE_KEY=your-alpha-vantage-key
JARVIS_FINNHUB_API_KEY=your-finnhub-key

# ============================================
# GitHub / Development
# ============================================
JARVIS_GITHUB_TOKEN=your-github-token
JARVIS_GITHUB_USERNAME=your-username

# ============================================
# Logging & Analytics
# ============================================
JARVIS_LOG_LEVEL=INFO
JARVIS_SENTRY_DSN=your-sentry-dsn
JARVIS_ANALYTICS_ENABLED=false

# ============================================
# Application Settings
# ============================================
JARVIS_ENVIRONMENT=development
JARVIS_DEBUG=false
JARVIS_PORT=5000
JARVIS_HOST=0.0.0.0
